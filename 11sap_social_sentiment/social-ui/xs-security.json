{
  "xsappname": "social-ui",
  "tenant-mode": "dedicated",
  "description": "Security profile of called application",
  "scopes": [
    {
      "name": "uaa.user",
      "description": "UAA"
    }
  ],
  "role-templates": [
    {
      "name": "Token_Exchange",
      "description": "UAA",
      "scope-references": [
        "uaa.user"
      ]
    }
  ],
    "authorities":["$ACCEPT_GRANTED_AUTHORITIES"],
  "oauth2-configuration": {
                      "token-validity": 900, 
                      "redirect-uris": ["https://*.cfapps.us10-001.hana.ondemand.com/login/callback"], 
                      "credential-types": ["binding-secret","x509"]
  },
  "xsenableasyncservice":"true"
}
